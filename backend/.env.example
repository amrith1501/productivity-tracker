# Required in production. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
PT_SECRET=

# production | development. Controls cookie Secure flag and SECRET fallback.
PT_ENV=production

# Comma-separated list of allowed frontend origins.
PT_ALLOWED_ORIGINS=https://your.app

# Optional. Session lifetime in seconds (default 3600 = 1h).
PT_TOKEN_TTL=3600
